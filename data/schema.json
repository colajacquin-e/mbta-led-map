{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/colajacquin-e/mbta-led-map/data/schema.json",
  "title": "MBTA LED Map Station Definitions",
  "description": "Schemas for line metadata and per-line LED definition files.",
  "$defs": {
    "line_metadata": {
      "title": "Line Metadata (lines.json)",
      "description": "Per-line configuration for rendering and hardware.",
      "type": "object",
      "patternProperties": {
        "^(red|orange|blue|green|mattapan)$": {
          "type": "object",
          "required": ["name", "color_hex", "led_count", "chain_gpio"],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "description": "Human-readable display name (e.g., \"Red Line\")."
            },
            "color_hex": {
              "type": "string",
              "pattern": "^#[0-9A-Fa-f]{6}$",
              "description": "CSS hex color for this line."
            },
            "led_count": {
              "type": "integer",
              "minimum": 0,
              "description": "Total number of LEDs on this chain."
            },
            "chain_gpio": {
              "type": "integer",
              "minimum": 0,
              "description": "ESP32 GPIO pin number for this chain's DIN signal."
            }
          }
        }
      },
      "additionalProperties": false
    },
    "led_entry": {
      "title": "LED Entry",
      "description": "A single LED mapped to a station platform or midpoint.",
      "type": "object",
      "required": [
        "index", "line", "stop_id", "stop_name",
        "direction", "direction_id", "type", "adjacent_stops",
        "x", "y"
      ],
      "additionalProperties": false,
      "properties": {
        "index": {
          "type": "integer",
          "minimum": 0,
          "description": "Zero-based position in this line's LED daisy chain."
        },
        "line": {
          "type": "string",
          "enum": ["red", "orange", "blue", "green", "mattapan"],
          "description": "Which subway line this LED belongs to."
        },
        "stop_id": {
          "description": "MBTA V3 API stop ID for station LEDs; null for midpoints.",
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "stop_name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable name. Stations: stop name. Midpoints: \"StopA – StopB\"."
        },
        "direction": {
          "type": "string",
          "enum": ["southbound", "northbound", "westbound", "eastbound", "inbound", "outbound"],
          "description": "Human-readable travel direction."
        },
        "direction_id": {
          "type": "integer",
          "enum": [0, 1],
          "description": "MBTA API direction_id (0 or 1) as provided by the API; meaning is route-specific."
        },
        "type": {
          "type": "string",
          "enum": ["station", "midpoint"],
          "description": "Whether this LED represents a station platform or a midpoint between stations."
        },
        "adjacent_stops": {
          "description": "For midpoints: the two MBTA stop IDs on either side. Null for stations.",
          "oneOf": [
            {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 2,
              "maxItems": 2
            },
            { "type": "null" }
          ]
        },
        "x": {
          "type": "number",
          "description": "Visual x-coordinate for map rendering."
        },
        "y": {
          "type": "number",
          "description": "Visual y-coordinate for map rendering."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "station" } } },
          "then": {
            "properties": {
              "stop_id": { "type": "string" },
              "adjacent_stops": { "type": "null" }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "midpoint" } } },
          "then": {
            "properties": {
              "stop_id": { "type": "null" },
              "adjacent_stops": { "type": "array" }
            }
          }
        }
      ]
    },
    "led_file": {
      "title": "Per-Line LED File (e.g., red.json)",
      "description": "Array of LED entries for a single line.",
      "type": "array",
      "items": { "$ref": "#/$defs/led_entry" }
    }
  }
}
